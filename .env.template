# -----------------------------------------------------------------------------
# Cats vs Dogs TicTacToe - Environment Variables Template
# -----------------------------------------------------------------------------
# INSTRUCTIONS:
# 1. Rename this file from '.env.template' to exactly '.env'
# 2. Paste your personal API keys below.
# 3. Do NOT commit the '.env' file to Git! It contains your secret keys.
# -----------------------------------------------------------------------------

# Google Gemini API Key (Required for 'go' agent)
GOOGLE_API_KEY="your_google_api_key_here"

# OpenRouter API Key (Required for routing to various LLMs)
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Hugging Face Token (Required for accessing specific OSS models)
HF_TOKEN="your_huggingface_token_here"

# Pinecone Vector Database API Key (If used for RAG/Memory)
PINECONE_API_KEY="your_pinecone_api_key_here"

# Tavily Search API Key (If used for agent web lookup)
TAVILY_API_KEY="your_tavily_api_key_here"
